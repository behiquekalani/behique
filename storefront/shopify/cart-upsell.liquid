{% comment %}
  Behike - Cart Page with Smart Upsell
  Dynamic upsell logic:
    - 1 blueprint in cart -> suggest "Get 5 for $47"
    - 3+ blueprints -> suggest "Get ALL for $97"
  Gift wrapping option (+$4.99)
  Black + Gold theme | Helvetica | Mobile responsive
{% endcomment %}

<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:#000;--text:#F5F5F7;--dim:#86868B;--gold:#C9A84C;
    --surface:#111;--border:#222;--radius:12px;--max:1080px;
  }
  body{background:var(--bg);color:var(--text);font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased}
  a{color:var(--gold);text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:var(--max);margin:0 auto;padding:0 24px}

  /* Nav */
  .bh-nav{position:sticky;top:0;z-index:100;background:rgba(0,0,0,.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
  .bh-nav .wrap{display:flex;align-items:center;justify-content:space-between;height:56px}
  .bh-nav .logo{font-size:18px;font-weight:600;letter-spacing:-.02em;color:var(--text)}
  .bh-nav .nav-links{display:flex;gap:28px;font-size:14px}
  .bh-nav .nav-links a{color:var(--dim);transition:color .2s}
  .bh-nav .nav-links a:hover{color:var(--text);text-decoration:none}
  .bh-nav .cart-link{position:relative}
  .bh-nav .cart-count{position:absolute;top:-6px;right:-10px;background:var(--gold);color:#000;font-size:10px;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center}

  /* Cart Header */
  .cart-header{padding:64px 0 32px;text-align:center}
  .cart-header h1{font-size:clamp(28px,4vw,42px);font-weight:700;letter-spacing:-.03em}
  .cart-header p{font-size:14px;color:var(--dim);margin-top:8px}

  /* Cart Layout */
  .cart-layout{display:grid;grid-template-columns:1fr 380px;gap:40px;padding-bottom:80px;align-items:start}

  /* Cart Items */
  .cart-items{display:flex;flex-direction:column;gap:0}
  .cart-item{display:grid;grid-template-columns:80px 1fr auto;gap:20px;align-items:center;padding:24px 0;border-bottom:1px solid var(--border)}
  .cart-item:first-child{border-top:1px solid var(--border)}
  .item-image{width:80px;height:80px;background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;display:flex;align-items:center;justify-content:center}
  .item-image img{width:100%;height:100%;object-fit:cover}
  .item-image .no-img{color:#333;font-size:12px}
  .item-info h3{font-size:15px;font-weight:600;margin-bottom:4px}
  .item-info .item-variant{font-size:13px;color:var(--dim)}
  .item-info .item-tag{display:inline-block;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--gold);border:1px solid rgba(201,168,76,.3);border-radius:4px;padding:2px 8px;margin-top:6px}
  .item-actions{text-align:right}
  .item-price{font-size:17px;font-weight:600;color:var(--gold);margin-bottom:8px}
  .qty-control{display:inline-flex;align-items:center;border:1px solid var(--border);border-radius:6px;overflow:hidden}
  .qty-control button{background:none;border:none;color:var(--dim);width:32px;height:32px;cursor:pointer;font-size:16px;font-family:inherit;transition:color .2s}
  .qty-control button:hover{color:var(--gold)}
  .qty-control input{width:36px;text-align:center;background:none;border:none;border-left:1px solid var(--border);border-right:1px solid var(--border);color:var(--text);font-size:14px;font-family:inherit;outline:none;-moz-appearance:textfield}
  .qty-control input::-webkit-inner-spin-button{-webkit-appearance:none}
  .item-remove{background:none;border:none;color:var(--dim);font-size:12px;cursor:pointer;margin-top:8px;font-family:inherit;transition:color .2s}
  .item-remove:hover{color:#FF453A}

  /* Upsell Banner */
  .upsell-banner{background:linear-gradient(135deg,rgba(201,168,76,.08),rgba(201,168,76,.02));border:1px solid rgba(201,168,76,.25);border-radius:var(--radius);padding:24px;margin-top:24px}
  .upsell-banner .upsell-badge{display:inline-block;font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);background:rgba(201,168,76,.12);padding:4px 10px;border-radius:4px;margin-bottom:12px;font-weight:600}
  .upsell-banner h3{font-size:18px;font-weight:600;margin-bottom:6px}
  .upsell-banner p{font-size:14px;color:var(--dim);margin-bottom:16px;line-height:1.4}
  .upsell-banner .upsell-price{display:flex;align-items:baseline;gap:8px;margin-bottom:16px}
  .upsell-banner .upsell-new{font-size:24px;font-weight:700;color:var(--gold)}
  .upsell-banner .upsell-old{font-size:14px;color:var(--dim);text-decoration:line-through}
  .upsell-banner .upsell-save{font-size:12px;color:#34C759;font-weight:600;background:rgba(52,199,89,.12);padding:3px 8px;border-radius:4px}
  .upsell-btn{display:block;width:100%;padding:12px;background:var(--gold);color:#000;font-size:14px;font-weight:600;font-family:inherit;border:none;border-radius:8px;cursor:pointer;transition:opacity .2s;text-align:center;text-decoration:none}
  .upsell-btn:hover{opacity:.88;text-decoration:none}

  /* Cart Summary */
  .cart-summary{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:32px;position:sticky;top:80px}
  .cart-summary h2{font-size:18px;font-weight:600;margin-bottom:24px}
  .summary-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;font-size:14px;color:var(--dim)}
  .summary-row.total{border-top:1px solid var(--border);margin-top:8px;padding-top:18px;font-size:18px;font-weight:600;color:var(--text)}
  .summary-row.total .total-price{color:var(--gold);font-size:22px}

  /* Gift Wrap Option */
  .gift-wrap{margin:20px 0;padding:16px;background:rgba(201,168,76,.04);border:1px solid var(--border);border-radius:8px}
  .gift-wrap label{display:flex;align-items:flex-start;gap:12px;cursor:pointer;font-size:14px;color:var(--dim)}
  .gift-wrap input[type="checkbox"]{margin-top:2px;accent-color:var(--gold);width:16px;height:16px;flex-shrink:0}
  .gift-wrap .gw-title{color:var(--text);font-weight:500;display:block}
  .gift-wrap .gw-price{color:var(--gold);font-weight:600}

  /* Checkout Button */
  .btn-checkout{display:block;width:100%;padding:16px;background:var(--gold);color:#000;font-size:16px;font-weight:600;font-family:inherit;border:none;border-radius:var(--radius);cursor:pointer;transition:opacity .2s;margin-top:20px}
  .btn-checkout:hover{opacity:.88}
  .checkout-note{text-align:center;font-size:12px;color:var(--dim);margin-top:12px}
  .checkout-note svg{width:12px;height:12px;vertical-align:middle;margin-right:4px}

  .continue-shopping{display:block;text-align:center;margin-top:16px;font-size:13px;color:var(--dim)}
  .continue-shopping:hover{color:var(--gold)}

  /* Empty Cart */
  .empty-cart{text-align:center;padding:120px 24px 80px}
  .empty-cart svg{width:64px;height:64px;stroke:var(--dim);fill:none;stroke-width:1;margin-bottom:24px}
  .empty-cart h2{font-size:24px;font-weight:600;margin-bottom:8px}
  .empty-cart p{font-size:15px;color:var(--dim);margin-bottom:32px}
  .empty-cart .browse-btn{display:inline-block;padding:14px 32px;background:var(--gold);color:#000;border-radius:980px;font-size:15px;font-weight:600;text-decoration:none;transition:opacity .2s}
  .empty-cart .browse-btn:hover{opacity:.88;text-decoration:none}

  /* Footer */
  .bh-footer{border-top:1px solid var(--border);padding:48px 24px;text-align:center}
  .bh-footer .brand{font-size:14px;font-weight:600;margin-bottom:8px}
  .bh-footer .meta{font-size:13px;color:var(--dim)}

  /* Responsive */
  @media(max-width:768px){
    .cart-layout{grid-template-columns:1fr;gap:24px}
    .cart-summary{position:static}
    .cart-item{grid-template-columns:64px 1fr;gap:12px}
    .item-actions{grid-column:1/-1;text-align:left;display:flex;align-items:center;gap:16px}
    .bh-nav .nav-links{gap:16px;font-size:13px}
  }
</style>

<!-- Navigation -->
<nav class="bh-nav">
  <div class="wrap">
    <a href="/" class="logo">behike</a>
    <div class="nav-links">
      <a href="/collections/all">Products</a>
      <a href="/pages/about">About</a>
      <a href="/cart" class="cart-link">
        Cart
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</nav>

{% if cart.item_count > 0 %}

  <!-- Cart Header -->
  <div class="cart-header">
    <h1>Your Cart</h1>
    <p>{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} in your cart</p>
  </div>

  <div class="wrap">
    <form action="/cart" method="post" id="cart-form">
      <div class="cart-layout">

        <!-- Left: Cart Items -->
        <div class="cart-left">
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item">
                <div class="item-image">
                  {% if item.image %}
                    <img src="{{ item.image | img_url: '160x' }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% else %}
                    <span class="no-img">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                      </svg>
                    </span>
                  {% endif %}
                </div>
                <div class="item-info">
                  <h3><a href="{{ item.url }}" style="color:inherit;text-decoration:none">{{ item.product.title }}</a></h3>
                  {% if item.variant.title != "Default Title" %}
                    <p class="item-variant">{{ item.variant.title }}</p>
                  {% endif %}
                  {% if item.product.type != blank %}
                    <span class="item-tag">{{ item.product.type }}</span>
                  {% endif %}
                </div>
                <div class="item-actions">
                  <div class="item-price">{{ item.line_price | money }}</div>
                  <div class="qty-control">
                    <button type="button" onclick="updateQty('{{ item.key }}', {{ item.quantity | minus: 1 }})" aria-label="Decrease quantity">&minus;</button>
                    <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                    <button type="button" onclick="updateQty('{{ item.key }}', {{ item.quantity | plus: 1 }})" aria-label="Increase quantity">+</button>
                  </div>
                  <button type="button" class="item-remove" onclick="updateQty('{{ item.key }}', 0)">Remove</button>
                </div>
              </div>
            {% endfor %}
          </div>

          <!-- ==================== SMART UPSELL ==================== -->
          {% comment %}
            Count how many blueprint-tagged items are in cart
          {% endcomment %}
          {% assign blueprint_count = 0 %}
          {% for item in cart.items %}
            {% assign item_tags = item.product.tags | join: ',' | downcase %}
            {% assign item_type = item.product.type | downcase %}
            {% if item_tags contains 'blueprint' or item_type contains 'blueprint' %}
              {% assign blueprint_count = blueprint_count | plus: item.quantity %}
            {% endif %}
          {% endfor %}

          {% comment %} Upsell Logic {% endcomment %}
          {% if blueprint_count >= 3 %}
            <!-- Upsell: Get ALL for $97 -->
            <div class="upsell-banner">
              <span class="upsell-badge">Upgrade & Save</span>
              <h3>You're building something serious.</h3>
              <p>You have {{ blueprint_count }} blueprints in your cart. Upgrade to the Full Operating System and get ALL current and future products.</p>
              <div class="upsell-price">
                <span class="upsell-new">$97</span>
                <span class="upsell-old">${{ blueprint_count | times: 1999 | divided_by: 100 }}.{{ blueprint_count | times: 1999 | modulo: 100 }}</span>
                <span class="upsell-save">Save big</span>
              </div>
              <a href="/products/full-os" class="upsell-btn">Get Everything for $97</a>
            </div>

          {% elsif blueprint_count >= 1 %}
            <!-- Upsell: Get 5 for $47 -->
            <div class="upsell-banner">
              <span class="upsell-badge">Bundle & Save</span>
              <h3>Get 5 blueprints for $47</h3>
              <p>You're buying {{ blueprint_count }} blueprint{% if blueprint_count != 1 %}s{% endif %} at $19.99 each. Grab the Builder Bundle and choose any 5 for just $47 -- that's less than $10 each.</p>
              <div class="upsell-price">
                <span class="upsell-new">$47</span>
                <span class="upsell-old">$99.95</span>
                <span class="upsell-save">Save 53%</span>
              </div>
              <a href="/products/builder-bundle" class="upsell-btn">Get the Builder Bundle</a>
            </div>
          {% endif %}

        </div>

        <!-- Right: Cart Summary -->
        <div class="cart-summary">
          <h2>Order Summary</h2>

          <div class="summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="summary-row">
            <span>Delivery</span>
            <span style="color:var(--gold)">Digital (instant)</span>
          </div>

          <!-- Gift Wrap Option -->
          <div class="gift-wrap">
            <label>
              <input type="checkbox" id="gift-wrap-check" onchange="toggleGiftWrap(this)">
              <div>
                <span class="gw-title">Add gift wrapping</span>
                Custom branded presentation + personalized message<br>
                <span class="gw-price">+ $4.99</span>
              </div>
            </label>
          </div>

          <div class="summary-row total">
            <span>Total</span>
            <span class="total-price" id="cart-total">{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" class="btn-checkout">Checkout</button>

          <p class="checkout-note">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure checkout. Instant digital delivery.
          </p>

          <a href="/collections/all" class="continue-shopping">Continue Shopping</a>
        </div>

      </div>
    </form>
  </div>

{% else %}

  <!-- Empty Cart -->
  <div class="empty-cart">
    <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"/>
      <circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
    </svg>
    <h2>Your cart is empty</h2>
    <p>Looks like you haven't added any products yet.</p>
    <a href="/collections/all" class="browse-btn">Browse Products</a>
  </div>

{% endif %}

<!-- Footer -->
<footer class="bh-footer">
  <div class="brand">behike</div>
  <p class="meta">Built in Puerto Rico. &copy; {{ 'now' | date: '%Y' }} Behike. <a href="/policies/terms-of-service" style="color:var(--dim)">Terms</a></p>
</footer>

<script>
/* Update item quantity via AJAX */
function updateQty(key, qty) {
  if (qty < 0) qty = 0;
  fetch('/cart/change.js', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({id: key, quantity: qty})
  }).then(function() {
    window.location.reload();
  });
}

/* Gift wrap toggle */
function toggleGiftWrap(checkbox) {
  var totalEl = document.getElementById('cart-total');
  var cartTotal = {{ cart.total_price }};
  if (checkbox.checked) {
    /* Add gift wrap product to cart */
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        items: [{
          id: {{ all_products['gift-wrapping'].variants.first.id | default: 0 }},
          quantity: 1
        }]
      })
    }).then(function(res) {
      if (res.ok) {
        window.location.reload();
      } else {
        /* Fallback: just show price update visually */
        var newTotal = (cartTotal + 499) / 100;
        totalEl.textContent = '$' + newTotal.toFixed(2);
      }
    });
  } else {
    /* Remove gift wrap */
    fetch('/cart/update.js', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        updates: { {{ all_products['gift-wrapping'].variants.first.id | default: 0 }}: 0 }
      })
    }).then(function(res) {
      if (res.ok) {
        window.location.reload();
      } else {
        var newTotal = cartTotal / 100;
        totalEl.textContent = '$' + newTotal.toFixed(2);
      }
    });
  }
}
</script>
