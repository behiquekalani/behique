{% comment %}
  Behike - Product Template
  Digital products store: SVG/PDF blueprints, guides, kits, OS
  Black + Gold theme | Helvetica | Mobile responsive
{% endcomment %}

<style>
  /* ============ PRODUCT PAGE ============ */
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:#000;--text:#F5F5F7;--dim:#86868B;--gold:#C9A84C;
    --surface:#111;--border:#222;--radius:12px;--max:1080px;
  }
  body{background:var(--bg);color:var(--text);font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased}
  a{color:var(--gold);text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:var(--max);margin:0 auto;padding:0 24px}

  /* Nav */
  .bh-nav{position:sticky;top:0;z-index:100;background:rgba(0,0,0,.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
  .bh-nav .wrap{display:flex;align-items:center;justify-content:space-between;height:56px}
  .bh-nav .logo{font-size:18px;font-weight:600;letter-spacing:-.02em;color:var(--text)}
  .bh-nav .nav-links{display:flex;gap:28px;font-size:14px}
  .bh-nav .nav-links a{color:var(--dim);transition:color .2s}
  .bh-nav .nav-links a:hover{color:var(--text);text-decoration:none}
  .bh-nav .cart-link{position:relative}
  .bh-nav .cart-count{position:absolute;top:-6px;right:-10px;background:var(--gold);color:#000;font-size:10px;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center}

  /* Breadcrumb */
  .breadcrumb{padding:16px 0;font-size:13px;color:var(--dim)}
  .breadcrumb a{color:var(--dim)}
  .breadcrumb a:hover{color:var(--gold)}
  .breadcrumb span{margin:0 8px}

  /* Product Layout */
  .product-layout{display:grid;grid-template-columns:1fr 1fr;gap:64px;padding:48px 0 80px;align-items:start}
  .product-image{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);aspect-ratio:1;display:flex;align-items:center;justify-content:center;overflow:hidden}
  .product-image img{width:100%;height:100%;object-fit:cover;border-radius:var(--radius)}
  .product-image .placeholder{color:var(--dim);font-size:14px;text-align:center;padding:40px}

  /* Product Info */
  .product-tag{display:inline-block;font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);border:1px solid var(--gold);border-radius:980px;padding:4px 14px;margin-bottom:16px}
  .product-title{font-size:clamp(28px,4vw,42px);font-weight:700;letter-spacing:-.03em;line-height:1.15;margin-bottom:12px}
  .product-subtitle{font-size:16px;color:var(--dim);margin-bottom:24px;line-height:1.5}

  /* Price */
  .price-block{display:flex;align-items:baseline;gap:12px;margin-bottom:24px}
  .price-current{font-size:32px;font-weight:700;color:var(--gold)}
  .price-compare{font-size:20px;color:var(--dim);text-decoration:line-through}
  .price-save{font-size:13px;color:#34C759;font-weight:600;background:rgba(52,199,89,.12);padding:4px 10px;border-radius:6px}

  /* Format selector */
  .format-label{font-size:13px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}
  .format-options{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap}
  .format-options label{display:block;cursor:pointer}
  .format-options input{display:none}
  .format-options .option{display:inline-block;padding:10px 20px;border:1px solid var(--border);border-radius:8px;font-size:14px;color:var(--dim);transition:all .2s}
  .format-options input:checked+.option{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.08)}

  /* Add to Cart */
  .btn-add-cart{display:block;width:100%;padding:16px;background:var(--gold);color:#000;font-size:16px;font-weight:600;font-family:inherit;border:none;border-radius:var(--radius);cursor:pointer;transition:opacity .2s;letter-spacing:-.01em}
  .btn-add-cart:hover{opacity:.88}
  .btn-add-cart:disabled{opacity:.4;cursor:not-allowed}
  .cart-note{text-align:center;font-size:12px;color:var(--dim);margin-top:10px}
  .cart-note svg{width:14px;height:14px;vertical-align:middle;margin-right:4px}

  /* Compatibility badges */
  .compat-section{margin-top:32px;padding-top:24px;border-top:1px solid var(--border)}
  .compat-label{font-size:12px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px}
  .compat-badges{display:flex;gap:8px;flex-wrap:wrap}
  .compat-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;background:var(--surface);border:1px solid var(--border);border-radius:980px;font-size:12px;color:var(--dim)}
  .compat-badge svg{width:14px;height:14px;fill:var(--dim)}

  /* Description */
  .product-description{padding:64px 0;border-top:1px solid var(--border);margin-top:64px}
  .product-description h2{font-size:24px;font-weight:600;letter-spacing:-.02em;margin-bottom:24px}
  .desc-content{color:var(--dim);font-size:15px;line-height:1.7}
  .desc-content h3{color:var(--text);font-size:18px;margin:24px 0 12px}
  .desc-content ul{padding-left:20px;margin:12px 0}
  .desc-content li{margin-bottom:6px}

  /* FAQ Accordion */
  .faq-section{padding:0 0 64px;border-top:1px solid var(--border);padding-top:48px}
  .faq-section h2{font-size:24px;font-weight:600;letter-spacing:-.02em;margin-bottom:24px}
  .faq-item{border-bottom:1px solid var(--border)}
  .faq-question{width:100%;background:none;border:none;padding:20px 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-family:inherit;font-size:16px;font-weight:500;color:var(--text);text-align:left}
  .faq-question:hover{color:var(--gold)}
  .faq-question svg{width:20px;height:20px;transition:transform .3s;flex-shrink:0;margin-left:16px;fill:var(--dim)}
  .faq-question[aria-expanded="true"] svg{transform:rotate(45deg)}
  .faq-answer{max-height:0;overflow:hidden;transition:max-height .3s ease}
  .faq-answer-inner{padding:0 0 20px;color:var(--dim);font-size:15px;line-height:1.6}

  /* Related Products */
  .related-section{padding:64px 0 80px;border-top:1px solid var(--border)}
  .related-section h2{font-size:24px;font-weight:600;letter-spacing:-.02em;margin-bottom:32px}
  .related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .related-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;transition:border-color .2s}
  .related-card:hover{border-color:var(--gold)}
  .related-card .rc-tag{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--gold);margin-bottom:10px}
  .related-card h3{font-size:16px;font-weight:600;margin-bottom:6px}
  .related-card .rc-desc{font-size:13px;color:var(--dim);margin-bottom:16px;line-height:1.4}
  .related-card .rc-bottom{display:flex;align-items:center;justify-content:space-between}
  .related-card .rc-price{font-size:18px;font-weight:600;color:var(--gold)}
  .related-card .rc-btn{padding:8px 18px;border:1px solid var(--gold);border-radius:980px;font-size:12px;color:var(--gold);transition:all .2s;text-decoration:none;display:inline-block}
  .related-card .rc-btn:hover{background:var(--gold);color:#000;text-decoration:none}

  /* Footer */
  .bh-footer{border-top:1px solid var(--border);padding:48px 24px;text-align:center}
  .bh-footer .brand{font-size:14px;font-weight:600;margin-bottom:8px}
  .bh-footer .meta{font-size:13px;color:var(--dim)}

  /* Responsive */
  @media(max-width:768px){
    .product-layout{grid-template-columns:1fr;gap:32px;padding:24px 0 48px}
    .related-grid{grid-template-columns:repeat(2,1fr)}
    .bh-nav .nav-links{gap:16px;font-size:13px}
  }
  @media(max-width:480px){
    .related-grid{grid-template-columns:1fr}
    .price-block{flex-wrap:wrap;gap:8px}
  }
</style>

<!-- Navigation -->
<nav class="bh-nav">
  <div class="wrap">
    <a href="/" class="logo">behike</a>
    <div class="nav-links">
      <a href="/collections/all">Products</a>
      <a href="/pages/about">About</a>
      <a href="/cart" class="cart-link">
        Cart
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</nav>

<div class="wrap">

  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/">Home</a><span>/</span>
    {% if product.collections.size > 0 %}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a><span>/</span>
    {% endif %}
    {{ product.title }}
  </div>

  <!-- Product Layout -->
  <div class="product-layout">

    <!-- Left: Product Image -->
    <div class="product-image">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
      {% else %}
        <div class="placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#86868B" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M3 16l5-5 4 4 4-6 5 7"/>
          </svg>
          <p style="margin-top:12px">Product Preview</p>
        </div>
      {% endif %}
    </div>

    <!-- Right: Product Info -->
    <div class="product-info">

      {% if product.type != blank %}
        <span class="product-tag">{{ product.type }}</span>
      {% elsif product.tags.size > 0 %}
        <span class="product-tag">{{ product.tags.first }}</span>
      {% endif %}

      <h1 class="product-title">{{ product.title }}</h1>

      {% if product.metafields.custom.subtitle %}
        <p class="product-subtitle">{{ product.metafields.custom.subtitle }}</p>
      {% else %}
        <p class="product-subtitle">{{ product.description | strip_html | truncatewords: 25 }}</p>
      {% endif %}

      <!-- Price -->
      <div class="price-block">
        <span class="price-current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="price-save">Save {{ savings }}%</span>
        {% endif %}
      </div>

      <!-- Variant / Format Selector (if variants exist) -->
      {% if product.variants.size > 1 %}
        <form action="/cart/add" method="post" id="product-form">
          <p class="format-label">Choose format</p>
          <div class="format-options">
            {% for variant in product.variants %}
              <label>
                <input type="radio" name="id" value="{{ variant.id }}"
                  {% if forloop.first %}checked{% endif %}
                  {% unless variant.available %}disabled{% endunless %}>
                <span class="option">{{ variant.title }}{% unless variant.available %} — Sold Out{% endunless %}</span>
              </label>
            {% endfor %}
          </div>
          <button type="submit" class="btn-add-cart" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}
              Add to Cart — {{ product.price | money }}
            {% else %}
              Sold Out
            {% endif %}
          </button>
        </form>
      {% else %}
        <form action="/cart/add" method="post" id="product-form">
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <button type="submit" class="btn-add-cart" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}
              Add to Cart — {{ product.price | money }}
            {% else %}
              Sold Out
            {% endif %}
          </button>
        </form>
      {% endif %}

      <p class="cart-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Instant digital delivery. Secure checkout.
      </p>

      <!-- Compatibility Badges -->
      <div class="compat-section">
        <p class="compat-label">Works with</p>
        <div class="compat-badges">
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
            GoodNotes
          </span>
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><path d="M5 3a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2H5z"/></svg>
            Figma
          </span>
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><path d="M4 4h16v16H4z"/></svg>
            Notion
          </span>
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
            PDF
          </span>
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/></svg>
            iPad
          </span>
          <span class="compat-badge">
            <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Desktop
          </span>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Product Description -->
<div class="wrap">
  <div class="product-description">
    <h2>What's Inside</h2>
    <div class="desc-content">
      {{ product.description }}
    </div>
  </div>
</div>

<!-- FAQ Accordion -->
<div class="wrap">
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>

    {% comment %} Pull FAQs from metafields or use defaults {% endcomment %}
    {% assign faq_questions = "How do I access my files after purchase?|What formats are included?|Can I use this for client work?|Do you offer refunds?|Will I get future updates?" | split: "|" %}
    {% assign faq_answers = "You'll receive an instant download link via email and in your Shopify account. Files are available immediately after payment.|Every product includes SVG, PDF, and where applicable, Figma and Notion templates. Check the product description for specific formats.|Yes. All products include a commercial license for personal and client use. You may not resell the templates themselves.|Due to the digital nature of our products, we don't offer refunds. But if something isn't working, reach out and we'll make it right.|Yes. All purchases include free lifetime updates. When we improve a product, you get the updated version at no extra cost." | split: "|" %}

    {% for question in faq_questions %}
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false" onclick="toggleFaq(this)">
          {{ question }}
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4v16M4 12h16"/></svg>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">{{ faq_answers[forloop.index0] }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<!-- Related Products -->
<div class="wrap">
  <div class="related-section">
    <h2>You might also like</h2>
    <div class="related-grid">
      {% assign related = product.collections.first.products | where: "available" %}
      {% assign count = 0 %}
      {% for item in related %}
        {% if item.id != product.id and count < 3 %}
          <a href="{{ item.url }}" class="related-card" style="text-decoration:none;color:inherit">
            <div class="rc-tag">
              {% if item.type != blank %}{{ item.type }}{% elsif item.tags.size > 0 %}{{ item.tags.first }}{% else %}Product{% endif %}
            </div>
            <h3>{{ item.title }}</h3>
            <p class="rc-desc">{{ item.description | strip_html | truncatewords: 15 }}</p>
            <div class="rc-bottom">
              <span class="rc-price">{{ item.price | money }}</span>
              <span class="rc-btn">View</span>
            </div>
          </a>
          {% assign count = count | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% comment %} Fallback if no related products found {% endcomment %}
      {% if count == 0 %}
        {% for item in collections.all.products limit:3 %}
          {% if item.id != product.id %}
            <a href="{{ item.url }}" class="related-card" style="text-decoration:none;color:inherit">
              <div class="rc-tag">
                {% if item.type != blank %}{{ item.type }}{% elsif item.tags.size > 0 %}{{ item.tags.first }}{% else %}Product{% endif %}
              </div>
              <h3>{{ item.title }}</h3>
              <p class="rc-desc">{{ item.description | strip_html | truncatewords: 15 }}</p>
              <div class="rc-bottom">
                <span class="rc-price">{{ item.price | money }}</span>
                <span class="rc-btn">View</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="bh-footer">
  <div class="brand">behike</div>
  <p class="meta">Built in Puerto Rico. &copy; {{ 'now' | date: '%Y' }} Behike. <a href="/policies/terms-of-service">Terms</a></p>
</footer>

<script>
function toggleFaq(btn) {
  var expanded = btn.getAttribute('aria-expanded') === 'true';
  // Close all
  document.querySelectorAll('.faq-question').forEach(function(q) {
    q.setAttribute('aria-expanded', 'false');
    q.nextElementSibling.style.maxHeight = null;
  });
  // Toggle current
  if (!expanded) {
    btn.setAttribute('aria-expanded', 'true');
    var answer = btn.nextElementSibling;
    answer.style.maxHeight = answer.scrollHeight + 'px';
  }
}
</script>
