          {
            "node": "Keyword Filter",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Keyword Filter": {
      "main": [
        [
          {
            "node": "OpenAI Summarize",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "OpenAI Summarize": {
      "main": [
        [
          {
            "node": "Format Carousel",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Carousel": {
      "main": [
        [
          {
            "node": "Schedule to Buffer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Schedule to Buffer": {
      "main": [
        [
          {
            "node": "Gmail Review Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
