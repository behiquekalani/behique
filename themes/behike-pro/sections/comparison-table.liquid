<section class="comparison-table section-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="comparison-table__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <table>
      <thead>
        <tr>
          <th>{{ section.settings.col1_header | default: "Feature" }}</th>
          <th>{{ section.settings.col2_header | default: "Basic" }}</th>
          <th>{{ section.settings.col3_header | default: "Premium" }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <td>{{ block.settings.feature }}</td>
            <td>{{ block.settings.col2_value }}</td>
            <td>{{ block.settings.col3_value }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "tag": "section",
  "class": "section-comparison-table",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Plans"
    },
    {
      "type": "text",
      "id": "col1_header",
      "label": "Column 1 header",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "col2_header",
      "label": "Column 2 header",
      "default": "Basic"
    },
    {
      "type": "text",
      "id": "col3_header",
      "label": "Column 3 header",
      "default": "Premium"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "col2_value",
          "label": "Column 2 value",
          "default": "-"
        },
        {
          "type": "text",
          "id": "col3_value",
          "label": "Column 3 value",
          "default": "Included"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "feature": "Free shipping", "col2_value": "Orders over $50", "col3_value": "All orders" } },
        { "type": "row", "settings": { "feature": "Priority support", "col2_value": "-", "col3_value": "Included" } },
        { "type": "row", "settings": { "feature": "Exclusive access", "col2_value": "-", "col3_value": "Included" } }
      ]
    }
  ]
}
{% endschema %}
