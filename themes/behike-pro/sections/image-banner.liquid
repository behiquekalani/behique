<section class="image-banner section-padding" style="min-height: {{ section.settings.min_height }}px;">
  {%- if section.settings.image != blank -%}
    <img
      class="image-banner__image"
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      width="1920"
      height="auto"
      loading="eager"
    >
  {%- endif -%}

  <div class="image-banner__overlay"></div>

  <div class="image-banner__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="image-banner__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="image-banner__text">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="image-banner__buttons">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Banner",
  "tag": "section",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Brand"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "Premium products designed for the modern entrepreneur."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 300,
      "max": 800,
      "step": 20,
      "default": 560,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Image Banner"
    }
  ]
}
{% endschema %}
