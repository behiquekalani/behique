<section class="testimonials section-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {%- for i in (1..block.settings.stars) -%}&#9733;{%- endfor -%}
          </div>
          <p class="testimonial-card__quote">"{{ block.settings.quote }}"</p>
          <p class="testimonial-card__author">{{ block.settings.author }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "This product changed everything for my business. Absolutely love it."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Incredible quality. Will definitely buy again.",
            "author": "Alex R."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Fast shipping and the product exceeded my expectations.",
            "author": "Maria L."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Best purchase I have made this year. Highly recommend.",
            "author": "Jordan K."
          }
        }
      ]
    }
  ]
}
{% endschema %}
