<section class="section-padding">
  <div class="page-width" style="max-width: 480px;">
    <h1 style="text-align: center;">Create Account</h1>
    {% form 'create_customer' %}
      <div style="margin-bottom: 1.6rem;">
        <label for="first_name">First name</label>
        <input type="text" name="customer[first_name]" id="first_name">
      </div>
      <div style="margin-bottom: 1.6rem;">
        <label for="last_name">Last name</label>
        <input type="text" name="customer[last_name]" id="last_name">
      </div>
      <div style="margin-bottom: 1.6rem;">
        <label for="email">Email</label>
        <input type="email" name="customer[email]" id="email" autocomplete="email">
      </div>
      <div style="margin-bottom: 2.4rem;">
        <label for="password">Password</label>
        <input type="password" name="customer[password]" id="password">
      </div>
      <button type="submit" class="button" style="width: 100%;">Create Account</button>
    {% endform %}
    <p style="text-align: center; margin-top: 2rem;"><a href="{{ routes.account_login_url }}">Already have an account? Sign in</a></p>
  </div>
</section>

{% schema %}
{
  "name": "Register",
  "tag": "section"
}
{% endschema %}
