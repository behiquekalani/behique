<section class="section-padding">
  <div class="page-width" style="max-width: 800px;">
    <h1>{{ article.title }}</h1>
    <p style="opacity: 0.6; margin-bottom: 3.2rem;">{{ article.published_at | date: '%B %d, %Y' }} &middot; {{ article.author }}</p>
    {%- if article.image -%}
      <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | default: article.title }}" style="border-radius: var(--border-radius-card); margin-bottom: 3.2rem; width: 100%;" loading="lazy">
    {%- endif -%}
    <div class="rich-text__text">{{ article.content }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Article",
  "tag": "section"
}
{% endschema %}
