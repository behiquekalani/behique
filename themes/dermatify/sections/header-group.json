{"name":"t:sections.header.name","type":"header","sections":{"announcement-bar":{"type":"announcement-bar","blocks":{"announcement-bar-0":{"type":"announcement","settings":{"text":"Valentine’s Treat: 50% Off Skincare Must-Haves!","text_alignment":"center","color_scheme":"accent-1","link":""}}},"block_order":["announcement-bar-0"],"custom_css":[],"settings":{}},"custom_liquid_YyabAr":{"type":"custom-liquid","disabled":true,"settings":{"custom_liquid":"<div class=\"holiday-header\" id=\"holiday-header\">\n  <div class=\"snowflake-container\">\n    <!-- 50 snowflakes -->\n    <div class=\"snowflake\" style=\"left: 5%; font-size: 18px; opacity: 0.8; animation-duration: 4s; animation-delay: 0s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 10%; font-size: 22px; opacity: 0.7; animation-duration: 5s; animation-delay: 1s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 15%; font-size: 25px; opacity: 0.6; animation-duration: 6s; animation-delay: 2s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 20%; font-size: 20px; opacity: 0.9; animation-duration: 4.5s; animation-delay: 0.5s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 25%; font-size: 28px; opacity: 1; animation-duration: 5.5s; animation-delay: 1.5s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 30%; font-size: 18px; opacity: 0.5; animation-duration: 6s; animation-delay: 3s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 35%; font-size: 23px; opacity: 0.8; animation-duration: 4.5s; animation-delay: 0.7s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 40%; font-size: 24px; opacity: 0.6; animation-duration: 5s; animation-delay: 2s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 45%; font-size: 20px; opacity: 0.7; animation-duration: 6.5s; animation-delay: 1s;\">*<\/div>\n    <div class=\"snowflake\" style=\"left: 50%; font-size: 26px; opacity: 0.9; animation-duration: 5.5s; animation-delay: 3.5s;\">*<\/div>\n  <\/div>\n  <p class=\"holiday-text\">🎁 <strong>Holiday Treats: 50% Off Skincare Must-Haves!<\/strong><\/p>\n<\/div>\n\n<style>\n.holiday-header {\n  position: fixed;\n  top: 0;\n  width: 100%;\n  background-color: #FFC1CC; \/* Updated light pink color *\/\n  color: #ffffff;\n  text-align: center;\n  padding: 20px 10px;\n  font-size: 22px; \/* Increased font size for main text *\/\n  font-weight: bold;\n  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n  z-index: 1000;\n  transition: transform 0.3s ease-in-out;\n}\n\n.holiday-header.hidden {\n  transform: translateY(-100%);\n}\n\n.holiday-text {\n  margin: 0;\n  z-index: 10;\n  font-size: 26px; \/* Larger font size for announcement text *\/\n}\n\n.snowflake-container {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n  overflow: hidden;\n  z-index: 1;\n}\n\n.snowflake {\n  position: absolute;\n  top: -10%;\n  color: #ffffff;\n  animation: fall linear infinite;\n}\n\n\/* Snowflake falling animation *\/\n@keyframes fall {\n  0% {\n    transform: translateY(-10%) rotate(0deg);\n  }\n  50% {\n    transform: translateY(50vh) rotate(180deg);\n  }\n  100% {\n    transform: translateY(100vh) rotate(360deg);\n  }\n}\n<\/style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    let lastScrollTop = 0;\n    const holidayHeader = document.getElementById('holiday-header');\n\n    window.addEventListener('scroll', () => {\n      const currentScrollTop = window.pageYOffset || document.documentElement.scrollTop;\n\n      if (currentScrollTop > lastScrollTop) {\n        \/\/ Scrolling down - hide header\n        holidayHeader.classList.add('hidden');\n      } else {\n        \/\/ Scrolling up - show header\n        holidayHeader.classList.remove('hidden');\n      }\n\n      lastScrollTop = currentScrollTop <= 0 ? 0 : currentScrollTop; \/\/ Prevent negative scroll values\n    });\n  });\n<\/script>","color_scheme":"background-1","padding_top":40,"padding_bottom":52}},"header":{"type":"header","settings":{"sticky_header_type":"on-scroll-up","show_line_separator":false,"color_scheme":"background-1","logo_link":"https:\/\/www.dermatify.com\/","logo_position":"middle-center","menu":"main-menu","menu_type_desktop":"dropdown","highlight_active_link":true,"highlighted_link_color_scheme":"accent-1","mobile_menu_title":"Quick Links","secondary_menu":"","menu_color_scheme":"background-1","mobile_logo_position":"center","display_search":false,"margin_bottom":0,"padding_top":4,"padding_bottom":4}}},"order":["announcement-bar","custom_liquid_YyabAr","header"]}