<section class="collapsible-content section-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="collapsible-content__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="collapsible-content__list">
      {%- for block in section.blocks -%}
        <details class="collapsible-content__item" {{ block.shopify_attributes }}>
          <summary class="collapsible-content__toggle">
            <span>{{ block.settings.heading }}</span>
            <svg class="collapsible-content__toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </summary>
          <div class="collapsible-content__body">
            {{ block.settings.content }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collapsible Content",
  "tag": "section",
  "class": "section-collapsible",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "collapsible_row",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Answer",
          "default": "<p>We offer a 30-day return policy on all items. If you are not satisfied with your purchase, you can return it for a full refund.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible Content",
      "blocks": [
        {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is your return policy?",
            "content": "<p>We offer a 30-day return policy on all items.</p>"
          }
        },
        {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long does shipping take?",
            "content": "<p>Standard shipping takes 5-7 business days. Express shipping is available at checkout.</p>"
          }
        },
        {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you ship internationally?",
            "content": "<p>Yes, we ship to most countries worldwide. Shipping rates are calculated at checkout.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
