<section class="section-padding">
  <div class="page-width" style="max-width: 480px;">
    <h1 style="text-align: center;">Login</h1>
    {% form 'customer_login' %}
      <div style="margin-bottom: 1.6rem;">
        <label for="email">Email</label>
        <input type="email" name="customer[email]" id="email" autocomplete="email">
      </div>
      <div style="margin-bottom: 2.4rem;">
        <label for="password">Password</label>
        <input type="password" name="customer[password]" id="password">
      </div>
      <button type="submit" class="button" style="width: 100%;">Sign In</button>
    {% endform %}
    <p style="text-align: center; margin-top: 2rem;"><a href="{{ routes.account_register_url }}">Create account</a></p>
  </div>
</section>

{% schema %}
{
  "name": "Login",
  "tag": "section"
}
{% endschema %}
