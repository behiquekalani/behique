<section class="icon-bar section-padding">
  <div class="page-width">
    <div class="icon-bar__grid">
      {%- for block in section.blocks -%}
        <div class="icon-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon == 'shipping' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="16" height="13" x="1" y="3" rx="1"/><path d="m17 8 4 2v6h-2"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
          {%- elsif block.settings.icon == 'support' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
          {%- elsif block.settings.icon == 'secure' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {%- elsif block.settings.icon == 'quality' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {%- endif -%}
          <h4 class="icon-bar__item-title">{{ block.settings.title }}</h4>
          <p class="icon-bar__item-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon Bar",
  "tag": "section",
  "class": "section-icon-bar",
  "settings": [],
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "support", "label": "Support" },
            { "value": "secure", "label": "Secure" },
            { "value": "quality", "label": "Quality" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "On orders over $50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Bar",
      "blocks": [
        { "type": "icon_item", "settings": { "icon": "shipping", "title": "Free Shipping", "text": "On orders over $50" } },
        { "type": "icon_item", "settings": { "icon": "support", "title": "24/7 Support", "text": "Always here to help" } },
        { "type": "icon_item", "settings": { "icon": "secure", "title": "Secure Payment", "text": "100% protected" } },
        { "type": "icon_item", "settings": { "icon": "quality", "title": "Premium Quality", "text": "Guaranteed satisfaction" } }
      ]
    }
  ]
}
{% endschema %}
