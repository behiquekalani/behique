<section class="section-padding">
  <div class="page-width">
    <h1>{{ blog.title }}</h1>
    <div class="grid grid--3" style="margin-top: 3.2rem;">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="card">
          {%- if article.image -%}
            <div class="card__image">
              <img src="{{ article.image | image_url: width: 400 }}" alt="{{ article.image.alt | default: article.title }}" loading="lazy">
            </div>
          {%- endif -%}
          <div class="card__content">
            <h3 class="card__title">{{ article.title }}</h3>
            <p style="font-size: 1.3rem; opacity: 0.6;">{{ article.published_at | date: '%B %d, %Y' }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "tag": "section"
}
{% endschema %}
