<section class="ticker">
  <div class="ticker__track">
    {%- for block in section.blocks -%}
      <span class="ticker__item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
    {%- endfor -%}
    {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
    {%- for block in section.blocks -%}
      <span class="ticker__item" aria-hidden="true">{{ block.settings.text }}</span>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Horizontal Ticker",
  "tag": "section",
  "class": "section-ticker",
  "settings": [],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping on All Orders"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Horizontal Ticker",
      "blocks": [
        { "type": "text_item", "settings": { "text": "Free Shipping Worldwide" } },
        { "type": "text_item", "settings": { "text": "Premium Quality Guaranteed" } },
        { "type": "text_item", "settings": { "text": "Limited Edition Drop" } },
        { "type": "text_item", "settings": { "text": "VIP Access Available" } },
        { "type": "text_item", "settings": { "text": "Handcrafted with Care" } }
      ]
    }
  ]
}
{% endschema %}
