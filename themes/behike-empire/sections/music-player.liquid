<section class="section-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 style="text-align: center; font-size: 3.2rem; margin: 0 0 3.2rem;">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="music-player">
      <div class="music-player__art">
        {%- if section.settings.artwork != blank -%}
          <img
            src="{{ section.settings.artwork | image_url: width: 480 }}"
            alt="{{ section.settings.track_title | default: 'Album art' }}"
            width="480"
            height="480"
            loading="lazy"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      <div class="music-player__info">
        <h3 class="music-player__title">{{ section.settings.track_title | default: "Track Title" }}</h3>
        <p class="music-player__artist">{{ section.settings.artist_name | default: "Artist Name" }}</p>
      </div>

      <div class="music-player__progress">
        <div class="music-player__progress-bar"></div>
      </div>

      <div class="music-player__controls">
        <button aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5" stroke="currentColor" stroke-width="2"/></svg>
        </button>
        <button aria-label="Play">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
        <button aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="2"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Music Player",
  "tag": "section",
  "class": "section-music-player",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Now Playing"
    },
    {
      "type": "image_picker",
      "id": "artwork",
      "label": "Album artwork"
    },
    {
      "type": "text",
      "id": "track_title",
      "label": "Track title",
      "default": "Golden Hour"
    },
    {
      "type": "text",
      "id": "artist_name",
      "label": "Artist name",
      "default": "The Artist"
    }
  ],
  "presets": [
    {
      "name": "Music Player"
    }
  ]
}
{% endschema %}
