        }
      }
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID_HERE",
        "text": "={{ $json.category === 'REFUND' ? '🚨 REFUND REQUEST' : $json.category === 'BUG' ? '🐛 BUG REPORT' : '📬 Support Ticket' }}\n\nCategory: {{ $json.category }} ({{ $json.confidence }}% confidence)\nFrom: {{ $json.originalEmail.from }}\nSubject: {{ $json.originalEmail.subject }}\n\nSummary: {{ $json.summary }}\n\nAuto-reply sent. Check Notion for full ticket.",
        "additionalFields": {}
      },
