{
  "name": "Support Triage",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "labelIds": ["INBOX"],
          "q": "to:support@behike.shop is:unread"
        },
        "options": {
          "dataPropertyAttachmentsPrefixName": "attachment_"
        }
      },
      "id": "d0e1f2a3-0001-4000-8000-000000000001",
      "name": "Gmail Trigger - New Support Email",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "YOUR_GMAIL_CREDENTIAL_ID",
          "name": "YOUR_GMAIL_CREDENTIAL_NAME"
        }
      }
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a support triage AI for Behike, a digital products brand. Classify the support email into exactly one category: REFUND, QUESTION, BUG, or FEEDBACK. Respond with ONLY the category word and a confidence score 0-100. Format: {\"category\": \"REFUND\", \"confidence\": 95, \"summary\": \"Customer wants refund for X because Y\"}"
            },
            {
              "role": "user",
              "content": "Classify this support email:\n\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\nBody: {{ $json.text || $json.snippet }}"
            }
          ]
        },
        "options": {
          "response_format": { "type": "json_object" }
        }
      },
      "id": "d0e1f2a3-0002-4000-8000-000000000002",
      "name": "OpenAI - Classify Email",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [460, 300],
      "credentials": {
        "openAiApi": {
          "id": "YOUR_OPENAI_CREDENTIAL_ID",
          "name": "YOUR_OPENAI_CREDENTIAL_NAME"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse OpenAI classification response\nconst item = $input.first();\nconst raw = item.json.choices?.[0]?.message?.content || '{}';\nlet classification;\n\ntry {\n  classification = JSON.parse(raw);\n} catch (e) {\n  classification = { category: 'QUESTION', confidence: 50, summary: 'Could not parse' };\n}\n\nreturn [{\n  json: {\n    ...item.json,\n    category: classification.category || 'QUESTION',\n    confidence: classification.confidence || 50,\n    summary: classification.summary || 'No summary',\n    originalEmail: {\n      from: $('Gmail Trigger - New Support Email').item.json.from,\n      subject: $('Gmail Trigger - New Support Email').item.json.subject,\n      body: $('Gmail Trigger - New Support Email').item.json.text || $('Gmail Trigger - New Support Email').item.json.snippet,\n      messageId: $('Gmail Trigger - New Support Email').item.json.id\n    }\n  }\n}];"
      },
      "id": "d0e1f2a3-0003-4000-8000-000000000003",
      "name": "Code - Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "REFUND",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "refund"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "QUESTION",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "question"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "BUG",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "bug"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "FEEDBACK",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "feedback"
            }
          ]
        },
        "options": {}
      },
      "id": "d0e1f2a3-0004-4000-8000-000000000004",
      "name": "Switch - Route by Category",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [900, 300]
    },
    {
      "parameters": {
        "fromEmail": "support@behike.shop",
        "toEmail": "={{ $json.originalEmail.from }}",
        "subject": "Re: {{ $json.originalEmail.subject }}",
        "emailType": "html",
        "message": "<p>Hi,</p><p>Thanks for reaching out. I received your refund request.</p><p>I process refunds within 48 hours. No questions asked. You'll receive a confirmation once it's processed.</p><p>If there was something wrong with your experience, I'd love to know so I can improve. But no pressure.</p><br><p>— Kalani<br>Behike Support</p>",
        "options": {}
      },
      "id": "d0e1f2a3-0005-4000-8000-000000000005",
      "name": "Gmail - Refund Auto-Reply",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [1120, 100],
      "credentials": {
        "gmailOAuth2": {
          "id": "YOUR_GMAIL_CREDENTIAL_ID",
          "name": "YOUR_GMAIL_CREDENTIAL_NAME"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "support@behike.shop",
        "toEmail": "={{ $json.originalEmail.from }}",
        "subject": "Re: {{ $json.originalEmail.subject }}",
