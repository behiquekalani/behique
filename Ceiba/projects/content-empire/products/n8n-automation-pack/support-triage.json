            { "key": "Category", "selectValue": "={{ $json.category }}" },
            { "key": "Summary", "textValue": "={{ $json.summary }}" },
            { "key": "Confidence", "numberValue": "={{ $json.confidence }}" },
            { "key": "Status", "selectValue": "Open" },
